// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "document_symbols": "on",
  "search": {
    "regex": true
  },
  "bottom_dock_layout": "full",
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": false
  },
  "document_folding_ranges": "on",
  "format_on_save": "off",
  "restore_on_startup": "last_workspace",
  "agent_buffer_font_size": 15.0,
  "agent_ui_font_size": 18.0,
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show_nav_history_buttons": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "max_tabs": 7,
  "which_key": {
    "delay_ms": 500,
    "enabled": true
  },
  "buffer_line_height": "standard",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    }
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "Fira Code",
  "vertical_scroll_margin": 7.0,
  "agent": {
    "dock": "left",
    "model_parameters": []
  },
  "project_panel": {
    "auto_reveal_entries": false,
    "dock": "right"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "helix_mode": true,
  "ui_font_size": 17.0,
  "buffer_font_size": 17.0,
  "theme": "JetBrains Light",
  "wrap_guides": [80, 120],
  "languages": {
    "PHP": {
      "language_servers": ["phpantom_lsp", "!intelephense", "!phpactor", "!phptools", "..."]
    }
  },
  "easy_motion": {
    "enabled": true,
    "keys": "tnseriaocdvhzkwfpyul"
  }
}
