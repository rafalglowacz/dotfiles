// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
      "ctrl-alt-k": ["task::Spawn", {"task_name": "Send file and line to Kitty"}],
      "cmd-alt-k": ["task::Spawn", {"task_name": "Send file and line to Kitty"}]
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "vim_mode == replace",
    "bindings": {
      "ctrl-v": "editor::Paste"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-v": "editor::Paste"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "alt-u": "vim::Up",
      "alt-e": "vim::Down",
      "alt-n": "vim::Left",
      "alt-i": "vim::Right"
    }
  },
  {
    "context": "(Editor && showing_completions)",
    "bindings": {
      "cmd-t": "editor::ComposeCompletion"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "space": null
    }
  },
  {
    "bindings": {
      "f6": "debugger::EvaluateSelectedText",
      "f7": "debugger::StepInto",
      "f8": "debugger::RunToCursor",
      "f10": "debugger::StepOver"
    }
  },
  {
    "context": "(!ContextEditor && !AcpThread) > (Editor && mode == full)",
    "bindings": {
      "alt-pagedown": "editor::GoToHunk",
      "alt-pageup": "editor::GoToPreviousHunk"
    }
  },
  {
    "context": "Pane && vim_mode == insert",
    "bindings": {
      "ctrl-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-w": null
    }
  },
  {
    "context": "(!ContextEditor && !AcpThread) > (Editor && mode == full)",
    "bindings": {
      "cmd-k e": "pane::RevealInProjectPanel"
    }
  },
  {
    "context": "(!ContextEditor && !AcpThread) > (Editor && mode == full)",
    "bindings": {
      "cmd-shift-e": null
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "+": null,
      "backspace": "editor::ScrollCursorTop",
      "shift-backspace": "editor::ScrollCursorBottom",
      "space shift-l": "editor::ReloadFile",
      "- i": "debugger::StepInto",
      "- o": "debugger::StepOver",
      "- shift-o": "debugger::StepOut"
    }
  },
  {
    "bindings": {
      "alt-escape": "editor::ToggleFocus"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "alt-t": [
        "easy_motion::Word",
        "both"
      ]
    }
  }
]
